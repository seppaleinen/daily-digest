{
  "name": "@daily-digest/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "db:push": "drizzle-kit push",
    "test": "vitest run --config vitest.config.ts",
    "test:unit": "vitest run --config vitest.config.ts -t unit",
    "test:integ": "vitest run --config vitest.config.ts -t integ",
    "test:e2e": "vitest run --config vitest.config.ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@daily-digest/shared": "workspace:*",
    "better-sqlite3": "12.10.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.25",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@daily-digest/tsconfig-base": "workspace:*",
    "@hono/node-server": "^1.13.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.2",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.6"
  }
}
