{
  // removed extends line
  "$schema": "./node_modules/turbo/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "vitest.config.*", "tsconfig*.json"],
      "outputs": []
    },
    "type-check": {
      "dependsOn": ["^type-check"],
      "inputs": ["src/**", "tsconfig*.json"],
      "outputs": []
    },
    "test:e2e": {
      "dependsOn": ["build"],
      "cache": false
    }
  }
}
